# ============================================
# AI_SDK - 环境变量配置示例
# 使用方式: cp .env.example .env 然后填入你的 API Key
# 安全: .env 已在 .gitignore 中，不会提交到仓库
# ============================================
#
# 加载方式:
#   source .env && cd test/build && ./LLMTest
#

# ---- DeepSeek API ----
export deepseekapikey="sk-your-deepseek-api-key-here"
export DEEPSEEK_API_KEY="${deepseekapikey}"

# ---- 智谱 GLM API ----
export glmapikey="your-glm-api-key-here"
export GLM_API_KEY="${glmapikey}"

# ---- Kimi / Moonshot API ----
export kimiapikey="your-kimi-api-key-here"
